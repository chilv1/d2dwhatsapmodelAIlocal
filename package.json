{
  "name": "telecombig-monorepo",
  "version": "1.0.0",
  "description": "Telecom Big Peru — Campaign Bot (WhatsApp+OpenAI) + CRM (Next.js)",
  "private": true,
  "workspaces": [
    "bot",
    "crm"
  ],
  "scripts": {
    "bot:start": "npm --workspace=bot start",
    "bot:dev": "npm --workspace=bot run dev",
    "bot:seed": "node bot/src/seed.js",
    "bot:test:vision": "npm --workspace=bot run test:vision",
    "crm:dev": "npm --workspace=crm run dev",
    "crm:build": "npm --workspace=crm run build",
    "crm:start": "npm --workspace=crm start",
    "crm:seed": "node crm/scripts/seed-admin.mjs",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=./prisma/schema.prisma",
    "prisma:reset": "prisma migrate reset --schema=./prisma/schema.prisma --force --skip-seed"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  },
  "engines": {
    "node": ">=20"
  }
}
