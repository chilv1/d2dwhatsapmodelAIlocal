# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_VISION_MODEL=gpt-4o
# Có thể chuyển sang gpt-4o-mini để giảm chi phí (chính xác thấp hơn)

# WhatsApp (whatsapp-web.js)
# Tên session — đổi nếu chạy nhiều bot
WA_SESSION_NAME=telecombig-bot

# Reply mode: "group" (trả lời trong group, tag người gửi) | "dm" (DM riêng)
REPLY_MODE=group

# Lọc group: chỉ xử lý message từ các group có trong danh sách (cách nhau bởi dấu phẩy)
# Để trống = lắng nghe TẤT CẢ group bot có trong đó
ALLOWED_GROUP_NAMES=

# Server admin
ADMIN_PORT=3000
ADMIN_API_KEY=changeme-admin-key

# Storage
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
TEMPLATE_DIR=./data/templates
DB_PATH=./data/telecombig.db
WA_SESSION_DIR=./data/wa-session

# Business rules
DEFAULT_CAMPAIGN_TARGET=20
SIMILARITY_THRESHOLD=70

# Logging
LOG_LEVEL=info
